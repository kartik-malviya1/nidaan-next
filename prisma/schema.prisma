// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gallery {
  id        String   @id @default(uuid())
  category  String?
  title     String?
  url       String // Cloudinary
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Donation {
  id            String   @id @default(uuid())
  panCard       String // Required for Indian tax compliance
  phoneNumber   String
  amount        Decimal  @db.Decimal(10, 2) // Prevents floating-point rounding errors
  name          String
  transactionId String   @unique // Tracks UTR ID / Transaction ID uniquely
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phoneNumber String
  message     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id           String   @id @default(uuid())
  type         String // "Volunteer" or "Internship"
  name         String
  email        String
  phone        String
  city         String
  institution  String
  area         String
  duration     String?
  availability String?
  motivation   String   @db.Text
  status       String   @default("pending") // pending, reviewed, accepted, rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AnnualReport {
  id         String  @id @default(uuid())
  year       String  @unique
  title      String
  highlights Json
  coverUrl   String
  pdfUrl     String
  featured   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
